rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    match /registrations/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /counters/{docId} {
      allow read, write: if true;
    }

    match /certificates/{certId} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAdmin();
    }

    // Public participant card verification by QR token.
    // Stores minimal non-sensitive fields shown on verify page.
    match /participant_cards/{token} {
      allow get: if true;
      allow list: if false;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /admin_requests/{uid} {
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /settings/directAccess {
      allow get: if true;
      allow list: if false;
      allow write: if isAdmin();
    }

  }
}
